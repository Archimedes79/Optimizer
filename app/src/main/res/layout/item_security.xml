<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Optimizer.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvSecurityName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="Security Name" />

        <TextView
            android:id="@+id/tvAlias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:text="Alias"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvIdentifier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:text="WKN/ISO" />

        <TextView
            android:id="@+id/tvEntries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:text="Entries: 0" />

        <TextView
            android:id="@+id/tvValues"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textHint"
            android:textSize="11sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Values: " />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
